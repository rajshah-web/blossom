{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Blossom application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user account was created."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        },
        "dailyReminders": {
          "type": "boolean",
          "description": "Whether the user has enabled daily reminders."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has a premium subscription to remove ads."
        }
      },
      "required": ["uid", "email", "createdAt", "role"]
    },
    "Cycle": {
      "title": "Cycle",
      "description": "A user's menstrual cycle record.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user this cycle belongs to."
        },
        "startDate": {
          "type": "string",
          "format": "date-time",
          "description": "The start date of the period."
        },
        "endDate": {
          "type": "string",
          "format": "date-time",
          "description": "The end date of the period, if it has ended."
        }
      },
      "required": ["userId", "startDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/cycles/{cycleId}": {
      "schema": {
        "$ref": "#/entities/Cycle"
      },
      "description": "Stores the user's menstrual cycles."
    }
  }
}
